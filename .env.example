# ─── Server ──────────────────────────────────────────────────────────────────
HTTP_PORT=3001
HTTPS_PORT=3443

# ─── HTTPS / SSL ────────────────────────────────────────────────────────────
# HTTPS is enabled by default.
# If key.pem / cert.pem are missing, a self-signed certificate is generated
# automatically at startup and saved to the ssl/ directory.
SSL_KEY_PATH=./ssl/key.pem
SSL_CERT_PATH=./ssl/cert.pem

# ─── CORS ────────────────────────────────────────────────────────────────────
# "allow-all"  → Access-Control-Allow-Origin: *
# "auto"       → Allow only host interfaces + configured ports
CORS_MODE=allow-all

# ─── Authentication ───────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
# Bcrypt hash of the admin password (cost factor 12).
# Generate: cd server && npm run hash-password
ADMIN_PASSWORD_HASH=
JWT_SECRET=change-me-to-a-long-random-string
REFRESH_SECRET=change-me-to-another-long-random-string

# ─── Network ─────────────────────────────────────────────────────────────────
# Interface assigned to the internal DHCP server — excluded from manual editing
DHCP_SERVER_INTERFACE=eth0

# Comma-separated list of interfaces blocked from port forwarding rules
BLOCKED_INTERFACES=lo

# Set to "true" if the device has a Wi-Fi adapter
HAS_WIFI=false

# ─── Setup ───────────────────────────────────────────────────────────────────
# Set to "true" after initial setup wizard completes
SETUP_DONE=false

# ─── Production ──────────────────────────────────────────────────────────────
# Path to the compiled client dist folder (relative to server/)
STATIC_PATH=../client/dist

# ─── Optional ────────────────────────────────────────────────────────────────
HOSTNAME=gateway
